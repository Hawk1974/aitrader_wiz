<Window x:Class="AiTrader.Wiz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:AiTrader.Wiz.Core;assembly=AiTrader.Wiz.Core"
        xmlns:local="clr-namespace:AiTrader.Wiz"
        Title="AlTrader Config Wizard"
        Height="930"
        Width="1280"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="HelpButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="350"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="32" Height="32">
                                    <Path Fill="#F2C96C"
                                          Stroke="#7A5A1B"
                                          StrokeThickness="1.8"
                                          Data="M16,3 C23.2,3 29,8.5 29,15.3 C29,22.1 23.2,27.6 16,27.6 C13.6,27.6 11.4,27 9.4,25.9 L4.6,29.2 L5.9,23.8 C4.1,21.6 3,18.6 3,15.3 C3,8.5 8.8,3 16,3 Z"/>
                                    <Rectangle Width="4.2"
                                               Height="11.5"
                                               RadiusX="2.1"
                                               RadiusY="2.1"
                                               Fill="#D94E3A"
                                               Canvas.Left="13.9"
                                               Canvas.Top="9.1"/>
                                    <Ellipse Width="4.2"
                                             Height="4.2"
                                             Fill="#D94E3A"
                                             Canvas.Left="13.9"
                                             Canvas.Top="5.1"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FFF9E8"/>
            <Setter Property="BorderBrush" Value="#C8A75B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#2D2417"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MaxWidth" Value="320"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="About" Click="AboutMenuItem_OnClick"/>
        </Menu>

        <TabControl x:Name="WizardTabs" Grid.Row="1">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="0. Start Here"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Overview of purpose, outputs, prerequisites, and manual-command boundaries."/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock FontSize="28" FontWeight="Bold" Text="AlTrader Config Wizard" ToolTip="The client-facing intake wizard for generating the AI overlay package."/>
                        <TextBlock Margin="0,12,0,0" FontSize="16" TextWrapping="Wrap"
                                   Text="Purpose: this tool helps a non-technical client produce the exact YAML and Markdown handoff files that a setup AI needs to stand up AlTrader." />
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                   Text="This wizard does not install Hermes, does not configure the backend, does not configure the desktop, does not modify the AlTrader repo zip, and does not enable live trading." />
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                   Text="When you finish, give the exported overlay files plus the static AlTrader repo zip to the setup AI. The setup AI will use the files from this wizard as the client-specific source of truth." />

                        <GroupBox Header="What This Wizard Produces" Margin="0,20,0,0" ToolTip="Lists every exported artifact the setup AI will receive.">
                            <StackPanel Margin="12">
                                <TextBlock TextWrapping="Wrap" Text="• CLIENT_INTAKE.yaml"/>
                                <TextBlock TextWrapping="Wrap" Text="• CLIENT_SUMMARY.md"/>
                                <TextBlock TextWrapping="Wrap" Text="• INSTRUCTION.md"/>
                                <TextBlock TextWrapping="Wrap" Text="• VALIDATION_SUMMARY.md"/>
                                <TextBlock TextWrapping="Wrap" Text="• SECRETS_STATUS.md"/>
                                <TextBlock TextWrapping="Wrap" Text="• one TARGET_*.md file per runtime target"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Before You Begin" Margin="0,16,0,0" ToolTip="Prerequisites the operator should gather before filling out the wizard.">
                            <StackPanel Margin="12">
                                <TextBlock TextWrapping="Wrap" Text="• Know how many computers are involved and what operating system each one uses."/>
                                <TextBlock TextWrapping="Wrap" Text="• Know which machine will host Hermes backend, Hermes Desktop, and LM Studio."/>
                                <TextBlock TextWrapping="Wrap" Text="• Have Alpaca paper credentials ready."/>
                                <TextBlock TextWrapping="Wrap" Text="• Have Telegram and AgentMail details ready if those services will be used."/>
                                <TextBlock TextWrapping="Wrap" Text="• If the backend and desktop are on different machines, have connectivity details ready such as Tailscale and SSH information."/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Manual Commands" Margin="0,16,0,0" ToolTip="Reference commands for manual kickoff and later live-credential staging.">
                            <StackPanel Margin="12">
                                <TextBlock FontWeight="Bold" Text="High Marshal"/>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Use these only when you are manually starting a chat-based workflow. Scheduled tasks remain unchanged."/>
                                <TextBlock Margin="0,8,0,0" FontFamily="Consolas" TextWrapping="Wrap" Text="{x:Static core:WizardStaticContent.HighMarshalFullKickoff}"/>
                                <TextBlock Margin="0,4,0,0" FontFamily="Consolas" TextWrapping="Wrap" Text="{x:Static core:WizardStaticContent.HighMarshalShortKickoff}"/>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Use High Marshal for manual trading-day kickoff. This does not replace the scheduled automatic kickoff."/>

                                <Separator Margin="0,14,0,14"/>

                                <TextBlock FontWeight="Bold" Text="Overlord"/>
                                <TextBlock Margin="0,8,0,0" FontFamily="Consolas" TextWrapping="Wrap" Text="{x:Static core:WizardStaticContent.OverlordGoLive}"/>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Use GO LIVE only to stage and confirm live-trading credentials. It is not a daily trading-day kickoff command."/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="1. Welcome"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Client and deployment identity fields used across the exported overlay."/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock FontSize="24" FontWeight="Bold" Text="Welcome" ToolTip="Introduces the client identity section."/>
                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"
                                   Text="This wizard creates the client-specific YAML and Markdown files that another AI will use, together with the static AlTrader repo zip, to stand up AlTrader in paper mode."/>
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="It does not install Hermes, does not stand up the backend, does not stand up the desktop, and does not enable live trading."/>

                        <GroupBox Header="Client Identity" Margin="0,18,0,0" ToolTip="Basic client and deployment identifiers that appear in the exports.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Client Name"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="The client name written into the exported overlay files."/>
                                </StackPanel>
                                <TextBox x:Name="ClientNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the client name as it should appear in exports."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Main Contact Name"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Primary client-side contact for this deployment."/>
                                </StackPanel>
                                <TextBox x:Name="MainContactNameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the main human contact name."/>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Main Contact Email"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Email address for the main deployment contact."/>
                                </StackPanel>
                                <TextBox x:Name="MainContactEmailTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the main contact email address."/>
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Deployment Name"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Short name for this deployment, pilot, or instance."/>
                                </StackPanel>
                                <TextBox x:Name="DeploymentNameTextBox" Grid.Row="3" Grid.Column="1" ToolTip="Enter the deployment name shown in summaries."/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="2. Computers"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Define the physical computers so runtime targets can be derived."/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock FontSize="20" FontWeight="Bold" Text="Physical Computers" ToolTip="Define the physical hosts involved in the deployment."/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock VerticalAlignment="Center" Text="How many computers are involved?"/>
                            <Button Style="{StaticResource HelpButtonStyle}" ToolTip="The wizard supports one or two physical computers."/>
                            <ComboBox x:Name="ComputerCountComboBox" Width="80" Margin="12,0,0,0" SelectionChanged="ComputerCountComboBox_OnSelectionChanged" ToolTip="Choose one machine for local/WSL setups or two for split deployments.">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2" IsSelected="True"/>
                            </ComboBox>
                        </StackPanel>

                        <GroupBox Header="Computer 1" Margin="0,16,0,0" ToolTip="Definition of the first physical machine.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Label"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Friendly host label used when targets are derived."/>
                                </StackPanel>
                                <TextBox x:Name="Computer1LabelTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter a recognizable label for the first computer."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Operating System"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="This determines which target kinds can be derived."/>
                                </StackPanel>
                                <ComboBox x:Name="Computer1OsComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" SelectionChanged="ComputerOsComboBox_OnSelectionChanged" ToolTip="Choose Windows, Linux, or macOS for computer 1."/>
                                <CheckBox x:Name="Computer1WslCheckBox" Grid.Row="2" Grid.Column="1" Content="This Windows machine will also host a WSL backend target" Checked="WslCheckBox_OnChanged" Unchecked="WslCheckBox_OnChanged" ToolTip="Enable this when the Windows machine should also expose a Linux backend target through WSL."/>
                            </Grid>
                        </GroupBox>

                        <GroupBox x:Name="Computer2GroupBox" Header="Computer 2" Margin="0,16,0,0" ToolTip="Definition of the optional second physical machine.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Label"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Friendly host label used when targets are derived."/>
                                </StackPanel>
                                <TextBox x:Name="Computer2LabelTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter a recognizable label for the second computer."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Operating System"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="This determines which target kinds can be derived."/>
                                </StackPanel>
                                <ComboBox x:Name="Computer2OsComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" SelectionChanged="ComputerOsComboBox_OnSelectionChanged" ToolTip="Choose Windows, Linux, or macOS for computer 2."/>
                                <CheckBox x:Name="Computer2WslCheckBox" Grid.Row="2" Grid.Column="1" Content="This Windows machine will also host a WSL backend target" Checked="WslCheckBox_OnChanged" Unchecked="WslCheckBox_OnChanged" ToolTip="Enable this when the second Windows machine should also expose a WSL backend target."/>
                            </Grid>
                        </GroupBox>

                        <Button Margin="0,16,0,0" Width="180" Height="32" Content="Derive Runtime Targets" Click="DeriveTargetsButton_OnClick" ToolTip="Recompute the runtime target list from the selected computer definitions."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="3. Targets"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Assign Hermes Backend, Hermes Desktop, LM Studio, primary desktop, and authoritative backend roles."/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel Margin="16">
                    <TextBlock DockPanel.Dock="Top" FontSize="20" FontWeight="Bold" Text="Runtime Targets" ToolTip="Derived targets and their assigned runtime roles."/>
                    <DataGrid x:Name="TargetsDataGrid" Margin="0,16,0,0" AutoGenerateColumns="False" CanUserAddRows="False" ToolTip="Assign exactly one authoritative backend and exactly one primary desktop.">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Target" Binding="{Binding DisplayName}" IsReadOnly="True" Width="2*"/>
                            <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" IsReadOnly="True" Width="*"/>
                            <DataGridCheckBoxColumn Header="Hermes Backend" Binding="{Binding HermesBackend}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Hermes Desktop" Binding="{Binding HermesDesktop}" Width="*"/>
                            <DataGridCheckBoxColumn Header="LM Studio" Binding="{Binding LmStudio}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Primary Desktop" Binding="{Binding IsPrimaryDesktop}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Authoritative Backend" Binding="{Binding IsAuthoritativeBackend}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="4. Connectivity + Backend"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Enter target-to-target connectivity details and backend runtime path settings."/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock FontSize="20" FontWeight="Bold" Text="Connectivity and Backend" ToolTip="Host, SSH, bootstrap, and backend path configuration."/>
                        <GroupBox Header="Connectivity" Margin="0,16,0,0" ToolTip="Network reachability and bootstrap details between desktop and backend targets.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Tailnet Name"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Tailscale network name if the deployment uses Tailscale."/>
                                </StackPanel>
                                <TextBox x:Name="TailnetNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the shared tailnet name, if applicable."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Backend Host or IP"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Reachable host or IP for the authoritative backend target."/>
                                </StackPanel>
                                <TextBox x:Name="BackendHostTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the backend machine address."/>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Desktop Host or IP"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Reachable host or IP for the primary desktop target."/>
                                </StackPanel>
                                <TextBox x:Name="DesktopHostTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the desktop machine address."/>
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="SSH Username"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Remote username the setup AI should use for backend access."/>
                                </StackPanel>
                                <TextBox x:Name="SshUserTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the SSH username."/>
                                <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="SSH Port"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="SSH port used for backend access, typically 22."/>
                                </StackPanel>
                                <TextBox x:Name="SshPortTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the SSH port number."/>
                                <CheckBox x:Name="RequiresTailscaleCheckBox" Grid.Row="5" Grid.Column="1" Content="This deployment requires Tailscale between targets" ToolTip="Check when cross-target connectivity depends on Tailscale."/>
                                <CheckBox x:Name="BootstrapCompleteCheckBox" Grid.Row="6" Grid.Column="1" Content="Bootstrap connectivity is already complete" ToolTip="Check when the initial connectivity/bootstrap work has already been finished."/>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="Backend Runtime Paths" Margin="0,16,0,0" ToolTip="Canonical backend filesystem locations for Hermes and AlTrader runtime data.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Hermes Home"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Base Hermes installation directory on the backend target."/>
                                </StackPanel>
                                <TextBox x:Name="HermesHomeTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the Hermes home path."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Repo Path"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Filesystem path where the AlTrader repo bundle should live on the backend."/>
                                </StackPanel>
                                <TextBox x:Name="RepoPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the backend repo path."/>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Data Path"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Primary runtime data directory for Hermes-managed state."/>
                                </StackPanel>
                                <TextBox x:Name="DataPathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the backend data path."/>
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="AlTrader Data Path"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Dedicated data directory for AlTrader runtime files."/>
                                </StackPanel>
                                <TextBox x:Name="AlTraderDataPathTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the AlTrader data path."/>
                                <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Models Path"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Directory containing model assets available to the deployment."/>
                                </StackPanel>
                                <TextBox x:Name="ModelsPathTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the models path."/>
                                <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Logs Path"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Directory where backend logs should be written."/>
                                </StackPanel>
                                <TextBox x:Name="LogsPathTextBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the logs path."/>
                                <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Backups Path"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Directory reserved for backups on the backend target."/>
                                </StackPanel>
                                <TextBox x:Name="BackupsPathTextBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the backups path."/>
                                <StackPanel Grid.Row="7" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Timezone"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="IANA timezone string used for scheduling and log interpretation."/>
                                </StackPanel>
                                <TextBox x:Name="TimezoneTextBox" Grid.Row="7" Grid.Column="1" ToolTip="Enter a timezone like America/New_York."/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="5. Services"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Configure LM Studio, Alpaca, Telegram, and AgentMail values for the deployment."/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock FontSize="20" FontWeight="Bold" Text="Service Configuration" ToolTip="External service endpoints and credentials used by the deployment."/>
                        <GroupBox Header="LM Studio" Margin="0,16,0,0" ToolTip="LM Studio API endpoint and target model information.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Base URL"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="HTTP base URL for the LM Studio API endpoint."/>
                                </StackPanel>
                                <TextBox x:Name="LmStudioBaseUrlTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the LM Studio base URL."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Model ID"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Exact model identifier expected to be available through LM Studio."/>
                                </StackPanel>
                                <TextBox x:Name="LmStudioModelIdTextBox" Grid.Row="1" Grid.Column="1" ToolTip="Enter the LM Studio model ID."/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Alpaca Paper" Margin="0,16,0,0" ToolTip="Paper-trading account settings used during initial standup.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Account Name"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Friendly label for the Alpaca paper account."/>
                                </StackPanel>
                                <TextBox x:Name="AlpacaPaperAccountTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the Alpaca paper account name or label."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="API Key"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Alpaca paper API key."/>
                                </StackPanel>
                                <local:SecretFieldControl x:Name="AlpacaPaperApiKeyControl" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" ToolTip="Paste the Alpaca paper API key."/>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Secret Key"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Alpaca paper secret key."/>
                                </StackPanel>
                                <local:SecretFieldControl x:Name="AlpacaPaperSecretControl" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" ToolTip="Paste the Alpaca paper secret key."/>
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Base URL"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Paper-trading API base URL."/>
                                </StackPanel>
                                <TextBox x:Name="AlpacaPaperBaseUrlTextBox" Grid.Row="3" Grid.Column="1" ToolTip="Enter the Alpaca paper base URL."/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Telegram" Margin="0,16,0,0" ToolTip="Telegram notification configuration.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Bot Token"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Telegram bot token used for message delivery."/>
                                </StackPanel>
                                <local:SecretFieldControl x:Name="TelegramBotTokenControl" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Paste the Telegram bot token."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Chat ID"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Telegram chat identifier used for notifications."/>
                                </StackPanel>
                                <TextBox x:Name="TelegramChatIdTextBox" Grid.Row="1" Grid.Column="1" ToolTip="Enter the Telegram chat ID."/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="AgentMail" Margin="0,16,0,0" ToolTip="AgentMail email-notification configuration.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="API Key"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="AgentMail bearer token used for validation and delivery."/>
                                </StackPanel>
                                <local:SecretFieldControl x:Name="AgentMailApiKeyControl" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" ToolTip="Paste the AgentMail API key."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="From ID"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="AgentMail inbox or sender identifier."/>
                                </StackPanel>
                                <TextBox x:Name="AgentMailFromIdTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" ToolTip="Enter the AgentMail from ID."/>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Recipient Email"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Destination email address for notifications."/>
                                </StackPanel>
                                <TextBox x:Name="AgentMailRecipientTextBox" Grid.Row="2" Grid.Column="1" ToolTip="Enter the notification recipient email."/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Optional Alpaca Live" Margin="0,16,0,0" ToolTip="Optional live credentials may be stored and validated without enabling live trading.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="AlpacaLiveEnabledCheckBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Content="Store and validate optional live credentials without enabling live trading" ToolTip="Enable this only to preserve live credentials for a later controlled GO LIVE step."/>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="API Key"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Optional Alpaca live API key."/>
                                </StackPanel>
                                <local:SecretFieldControl x:Name="AlpacaLiveApiKeyControl" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" ToolTip="Paste the optional Alpaca live API key."/>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Secret Key"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Optional Alpaca live secret key."/>
                                </StackPanel>
                                <local:SecretFieldControl x:Name="AlpacaLiveSecretControl" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" ToolTip="Paste the optional Alpaca live secret key."/>
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Base URL"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Live-trading API base URL."/>
                                </StackPanel>
                                <TextBox x:Name="AlpacaLiveBaseUrlTextBox" Grid.Row="3" Grid.Column="1" ToolTip="Enter the Alpaca live base URL."/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="6. Cash Allocation"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Set reserve, per-ticker allocation, and ranked-candidate policy values."/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock FontSize="20" FontWeight="Bold" Text="Cash Allocation" ToolTip="Client-facing cash reserve and position-allocation policy settings."/>
                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"
                                   Text="These fields control the client-facing reserve and per-ticker cash-allocation policy that the setup AI will write into the AlTrader instance."/>

                        <GroupBox Header="Calculation Basis" Margin="0,16,0,0" ToolTip="Reference cash basis used to preview percent-based values in dollars.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Start-of-Day Cash Basis ($)"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Reference cash balance used for helper calculations."/>
                                </StackPanel>
                                <TextBox x:Name="CashBasisTextBox"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="0,0,0,8"
                                         ToolTip="Enter the typical start-of-day cash balance."
                                         TextChanged="CashAllocationField_OnTextChanged"
                                         LostFocus="CashAllocationField_OnLostFocus"
                                         PreviewTextInput="DecimalField_OnPreviewTextInput"
                                         DataObject.Pasting="DecimalField_OnPasting"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="DimGray" TextWrapping="Wrap"
                                           Text="Use this to preview the dollar impact of percent-based settings. Example: 25000 shows what 10% means for a $25,000 start-of-day cash balance."/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Protected Reserve" Margin="0,16,0,0" ToolTip="Amount of cash held back from allocation.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                    <RadioButton x:Name="ProtectedReservePercentRadio" GroupName="ProtectedReserveMode" Content="%" IsChecked="True" Checked="CashAllocationMode_OnChecked" ToolTip="Interpret reserve as a percentage of the cash basis."/>
                                    <RadioButton x:Name="ProtectedReserveDollarRadio" GroupName="ProtectedReserveMode" Content="$" Margin="18,0,0,0" Checked="CashAllocationMode_OnChecked" ToolTip="Interpret reserve as a fixed dollar amount."/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Reserve Value"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Protected reserve value in the selected mode."/>
                                </StackPanel>
                                <TextBox x:Name="ProtectedReserveValueTextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="0,0,0,8"
                                         ToolTip="Enter the protected reserve value."
                                         TextChanged="CashAllocationField_OnTextChanged"
                                         LostFocus="CashAllocationField_OnLostFocus"
                                         PreviewTextInput="DecimalField_OnPreviewTextInput"
                                         DataObject.Pasting="DecimalField_OnPasting"/>
                                <TextBlock x:Name="ProtectedReserveHelperTextBlock" Grid.Row="2" Grid.Column="1" Foreground="DimGray" TextWrapping="Wrap"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Per-Ticker Allocation" Margin="0,16,0,0" ToolTip="Maximum allocation allowed per ranked ticker.">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                    <RadioButton x:Name="PerTickerPercentRadio" GroupName="PerTickerMode" Content="%" IsChecked="True" Checked="CashAllocationMode_OnChecked" ToolTip="Interpret allocation as a percentage of the cash basis."/>
                                    <RadioButton x:Name="PerTickerDollarRadio" GroupName="PerTickerMode" Content="$" Margin="18,0,0,0" Checked="CashAllocationMode_OnChecked" ToolTip="Interpret allocation as a fixed dollar amount."/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="Allocation Value"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Per-ticker allocation value in the selected mode."/>
                                </StackPanel>
                                <TextBox x:Name="PerTickerValueTextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="0,0,0,8"
                                         ToolTip="Enter the per-ticker allocation value."
                                         TextChanged="CashAllocationField_OnTextChanged"
                                         LostFocus="CashAllocationField_OnLostFocus"
                                         PreviewTextInput="DecimalField_OnPreviewTextInput"
                                         DataObject.Pasting="DecimalField_OnPasting"/>
                                <TextBlock x:Name="PerTickerHelperTextBlock" Grid.Row="2" Grid.Column="1" Foreground="DimGray" TextWrapping="Wrap"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Ranked Candidate Limit" Margin="0,16,0,0" ToolTip="Cap on how many ranked candidates the deployment should consider per cycle.">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="Max Ranked Candidates"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Positive integer limit for candidates processed per cycle."/>
                                </StackPanel>
                                <TextBox x:Name="MaxRankedCandidatesTextBox"
                                         Grid.Column="1"
                                         ToolTip="Enter the maximum number of ranked candidates."
                                         TextChanged="CashAllocationField_OnTextChanged"
                                         LostFocus="CashAllocationField_OnLostFocus"
                                         PreviewTextInput="IntegerField_OnPreviewTextInput"
                                         DataObject.Pasting="IntegerField_OnPasting"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="7. Review + Export"/>
                        <Button Style="{StaticResource HelpButtonStyle}" ToolTip="Save drafts, run validations, inspect log output, and export the overlay zip."/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="140" Height="32" Margin="0,0,10,0" Content="Save Draft" Click="SaveDraftButton_OnClick" ToolTip="Encrypt and save the current wizard state locally."/>
                        <Button Width="140" Height="32" Margin="0,0,10,0" Content="Load Draft" Click="LoadDraftButton_OnClick" ToolTip="Load the previously saved encrypted draft, if present."/>
                        <Button Width="140" Height="32" Margin="0,0,10,0" Content="Wipe Draft" Click="WipeDraftButton_OnClick" ToolTip="Delete the saved encrypted draft from local storage."/>
                        <Button Width="160" Height="32" Margin="0,0,10,0" Content="Run Validations" Click="RunValidationsButton_OnClick" ToolTip="Validate topology, connectivity, and service endpoints."/>
                        <Button Width="180" Height="32" Content="Export Overlay Zip" Click="ExportButton_OnClick" ToolTip="Export the AI overlay files into a zip for handoff."/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Margin="0,12,0,12" TextWrapping="Wrap"
                               Text="Review the log below. The exported files are the AI overlay only. Hand those files plus the static AlTrader repo zip to the setup AI."/>
                    <TextBox x:Name="LogTextBox" Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" ToolTip="Displays validation, draft, and export status messages."/>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button DockPanel.Dock="Left" x:Name="ExitButton" Width="120" Height="34" Content="Cancel / Exit" Click="ExitButton_OnClick" ToolTip="Exit the wizard without exporting the overlay zip."/>
            <Button DockPanel.Dock="Right" x:Name="NextButton" Width="110" Height="34" Margin="12,0,0,0" Content="Next" Click="NextButton_OnClick" ToolTip="Move to the next wizard tab."/>
            <Button DockPanel.Dock="Right" x:Name="BackButton" Width="110" Height="34" Content="Back" Click="BackButton_OnClick" ToolTip="Return to the previous wizard tab."/>
        </DockPanel>
    </Grid>
</Window>
