<Window x:Class="AiTrader.Wiz.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:AiTrader.Wiz.Core;assembly=AiTrader.Wiz.Core"
        Title="About AlTrader Config Wizard"
        Width="520"
        Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="Bold" Text="AlTrader Config Wizard"/>
            <TextBlock Margin="0,16,0,0" TextWrapping="Wrap">
                <Run FontWeight="Bold" Text="Tool Creator: "/>
                <Run Text="{x:Static core:WizardStaticContent.ToolCreator}"/>
            </TextBlock>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap">
                <Run FontWeight="Bold" Text="Email: "/>
                <Run Text="{x:Static core:WizardStaticContent.SupportEmail}"/>
            </TextBlock>
            <TextBlock Margin="0,12,0,0" FontWeight="Bold" Text="Info:"/>
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{x:Static core:WizardStaticContent.AboutInfo}"/>
            <TextBlock Margin="0,16,0,0" FontWeight="Bold" Text="{x:Static core:WizardStaticContent.LegalHeading}"/>
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{x:Static core:WizardStaticContent.LegalNotice}"/>
        </StackPanel>

        <Button Grid.Row="1"
                Width="100"
                Height="34"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Content="Close"
                IsDefault="True"
                Click="CloseButton_OnClick"/>
    </Grid>
</Window>
