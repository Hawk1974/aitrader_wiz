<UserControl x:Class="AiTrader.Wiz.SecretFieldControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="30">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <PasswordBox x:Name="MaskedInput"
                         VerticalContentAlignment="Center"
                         PasswordChanged="MaskedInput_OnPasswordChanged"/>
            <TextBox x:Name="VisibleInput"
                     VerticalContentAlignment="Center"
                     Visibility="Collapsed"
                     TextChanged="VisibleInput_OnTextChanged"/>
        </Grid>

        <Button x:Name="ToggleButton"
                Grid.Column="1"
                Width="34"
                Margin="8,0,0,0"
                Click="ToggleButton_OnClick"
                ToolTip="Show or hide this value">
            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE890;" FontSize="14" />
        </Button>
    </Grid>
</UserControl>
